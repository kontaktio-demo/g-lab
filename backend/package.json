{
  "name": "g-lab-backend",
  "version": "1.0.0",
  "private": true,
  "description": "G-Lab backend API — REST + image pipeline (sharp → AVIF/WebP) na bazie Supabase. Deploy: Render.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "blurhash": "^2.0.5",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "file-type": "^19.6.0",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "nanoid": "^5.0.7",
    "nodemailer": "^7.0.11",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.33.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.10",
    "@types/nodemailer": "^6.4.16",
    "@types/swagger-ui-express": "^4.1.7",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^8.57.1",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
