# ────────────────────────────────────────────────────────────────────
#  G-Lab Backend — przykładowe zmienne środowiskowe
#  Skopiuj do `.env` i wypełnij wartościami z Supabase / Render.
# ────────────────────────────────────────────────────────────────────

# Środowisko: development | production | test
NODE_ENV=development

# Port HTTP (Render ustawia automatycznie zmienną PORT)
PORT=4000

# Adres hosta (zwykle 0.0.0.0 dla kontenerów; 127.0.0.1 lokalnie)
HOST=0.0.0.0

# ── Supabase ────────────────────────────────────────────────────────
# URL projektu, np. https://abcd.supabase.co
SUPABASE_URL=

# Klucz "anon" (public) — używany do walidacji JWT zwykłych użytkowników.
SUPABASE_ANON_KEY=

# Klucz "service_role" (secret) — pełny dostęp z poziomu backendu (omija RLS).
# NIGDY nie eksponować w przeglądarce!
SUPABASE_SERVICE_ROLE_KEY=

# Nazwa bucketa Storage (musi istnieć — patrz supabase/schema.sql)
SUPABASE_BUCKET=realizacje

# ── CORS ────────────────────────────────────────────────────────────
# Lista dozwolonych originów po przecinku, np.:
#   https://g-lab.pl,https://www.g-lab.pl,https://g-lab-cms.vercel.app
# Użyj "*" tylko w developmencie.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# ── Image pipeline ──────────────────────────────────────────────────
# Maksymalny rozmiar pojedynczego pliku obrazu (bajty), domyślnie 15 MB.
MAX_UPLOAD_BYTES=15728640

# Szerokości generowane dla srcset, po przecinku.
IMAGE_WIDTHS=480,1280,2400

# Jakość AVIF (1-100, niżej = mniejsze pliki)
AVIF_QUALITY=50

# Jakość WebP
WEBP_QUALITY=80

# Jakość JPEG fallback
JPEG_QUALITY=82

# ── Rate limit ──────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LEADS_RATE_LIMIT_MAX=5

# ── SMTP (opcjonalne — powiadomienia o nowych leadach) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="G-Lab <kontakt@g-lab.pl>"
SMTP_TO=kontakt@g-lab.pl

# ── Webhook revalidate (HMAC dla rebuilda strony statycznej) ────────
# Opcjonalnie: jeśli ustawisz, backend będzie walidował podpis nagłówka X-Hub-Signature-256.
REVALIDATE_SECRET=
# Pełny URL deploy hooka Netlify / Vercel, który zostanie wywołany.
REVALIDATE_HOOK_URL=

# ── Logger ──────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
