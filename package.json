{
  "name": "g-lab",
  "version": "1.0.0",
  "description": "Strona G-Lab Chip Tuning - statyczny generator (Node.js + vanilla HTML/CSS/JS) z katalogiem tuningu z CSV i sekcją realizacji edytowalną przez Decap CMS.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "node build.js",
    "serve": "node -e \"const http=require('http'),fs=require('fs'),path=require('path'),mime={'.html':'text/html;charset=utf-8','.css':'text/css','.js':'text/javascript','.json':'application/json','.svg':'image/svg+xml','.png':'image/png','.jpg':'image/jpeg','.xml':'application/xml','.yml':'text/yaml','.ico':'image/x-icon','.webp':'image/webp'};http.createServer((req,res)=>{let p=path.join('public',decodeURIComponent(req.url.split('?')[0]));if(p.endsWith('/'))p+='index.html';fs.stat(p,(e,s)=>{if(!e&&s.isDirectory())p=path.join(p,'index.html');fs.readFile(p,(e,d)=>{if(e){res.writeHead(404);return res.end('404');}res.writeHead(200,{'Content-Type':mime[path.extname(p)]||'application/octet-stream'});res.end(d);});});}).listen(8080,()=>console.log('http://localhost:8080'));\"",
    "dev": "npm run build && npm run serve"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2"
  }
}
